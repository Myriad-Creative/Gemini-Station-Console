{
  "schema_version": "1.1",
  "config_name": "space_ship_mod_naming",
  "description": "Functional, hardware-like procedural naming for normal procedural gear. Uses primary-stat-based leading prefixes and level-band uniqueness controls to reduce duplicate names. Manufacturer or program prefixes are reserved for future higher-end gear.",
  "normal_procedural_style": {
    "manufacturer_prefixes_enabled": false,
    "program_names_enabled": false,
    "goal_examples": [
      "Armored Panels",
      "Shield Generator",
      "Stealth Chip",
      "Energy Blaster",
      "Targeting Module",
      "Recovery Relay",
      "Deepfield Recon Scanner",
      "Sentinel Barrier Emitter",
      "Flux Recovery Relay",
      "Pinpoint Targeting Module"
    ]
  },
  "naming_order": [
    "select_core_phrase_from_phrase_override_or_two_word_fallback",
    "check_uniqueness_within_batch_and_level_band",
    "reroll_unused_core_phrase_when_available",
    "apply_primary_stat_prefix_for_collision_or_rarity",
    "reroll_prefix_until_unique_or_pool_exhausted",
    "fallback_to_constructed_prefixed_name_if_needed"
  ],
  "templates": {
    "two_word": "{descriptor} {component}",
    "prefixed_phrase": "{prefix} {core_phrase}",
    "prefixed_two_word": "{prefix} {descriptor} {component}",
    "prefixed_base_term": "{prefix} {base_term} {component}"
  },
  "generation_preferences": {
    "use_phrase_override_when_available": true,
    "allow_fallback_when_override_exists": false,
    "core_phrase_is_two_word_by_default": true,
    "prefix_on_collision_before_allowing_reuse": true,
    "prefix_can_be_used_even_if_unique_based_on_rarity": true,
    "three_word_names_allowed_for_all_rarities_on_collision": true,
    "three_word_names_preferred_for_higher_rarity": true,
    "prefer_unused_phrase_overrides_within_scope": true,
    "prefer_unused_prefixes_within_scope": true,
    "prefix_source": "primary_stat",
    "secondary_modifier_source_priority": [
      "secondary_stat_descriptor",
      "primary_stat_descriptor"
    ],
    "fallback_descriptor_source": "primary_stat",
    "fallback_component_source": "slot",
    "title_case_output": true,
    "preserve_hyphenation": true
  },
  "style_rules": {
    "disallow_of_construction": true,
    "disallow_duplicate_full_tokens": true,
    "disallow_duplicate_roots": true,
    "disallow_component_repetition": true,
    "avoid_descriptor_component_echo": true,
    "armor_components_can_be_plural": true,
    "electronic_components_prefer_singular": true,
    "weapon_mod_component_preference": [
      "Coupler",
      "Lens",
      "Emitter",
      "Chamber",
      "Hardpoint",
      "Mount",
      "Accelerator",
      "Rail",
      "Blaster",
      "Cannon"
    ]
  },
  "uniqueness_rules": {
    "scope": "level_band_and_batch",
    "level_band_size": 10,
    "allow_exact_name_reuse_across_bands": true,
    "block_exact_name_reuse_within_band": true,
    "block_exact_name_reuse_within_batch": true,
    "avoid_same_core_phrase_within_band_when_alternatives_exist": true,
    "avoid_same_prefix_with_same_core_phrase_within_band_when_alternatives_exist": true,
    "upgrade_to_prefixed_name_on_collision": true,
    "reroll_core_phrase_before_prefix_if_unused_core_phrase_exists": true,
    "reroll_prefix_on_collision": true,
    "max_core_phrase_rerolls": 8,
    "max_prefix_rerolls": 12,
    "resolution_sequence": [
      "reroll_unused_core_phrase",
      "apply_prefix",
      "reroll_prefix",
      "fallback_to_constructed_name",
      "least_recently_used"
    ],
    "fallback_strategy_when_pool_exhausted": "least_recently_used"
  },
  "prefix_usage_rules": {
    "common": {
      "use_prefix_if_unique_chance": 0.15,
      "use_prefix_on_collision": 1.0
    },
    "uncommon": {
      "use_prefix_if_unique_chance": 0.35,
      "use_prefix_on_collision": 1.0
    },
    "rare": {
      "use_prefix_if_unique_chance": 0.65,
      "use_prefix_on_collision": 1.0
    },
    "epic": {
      "use_prefix_if_unique_chance": 0.85,
      "use_prefix_on_collision": 1.0
    },
    "legendary": {
      "use_prefix_if_unique_chance": 1.0,
      "use_prefix_on_collision": 1.0
    }
  },
